diff -ur wireguard/receive.c QUICwireguard/receive.c
--- wireguard/receive.c	2024-12-14 20:18:36.077181314 +0300
+++ QUICwireguard/receive.c	2024-12-14 20:17:25.857431420 +0300
@@ -69,8 +69,18 @@
 		 * its size.
 		 */
 		return -EINVAL;
-	data_len -= sizeof(struct udphdr);
-	data_offset = (u8 *)udp + sizeof(struct udphdr) - skb->data;
+	if ((be16_to_cpu(udp->source) == QUIC_PORT) || (be16_to_cpu(udp->dest) == QUIC_PORT)) {
+		if (*((u8 *)udp + sizeof(struct udphdr)) > 4) {
+			data_len -= sizeof(struct udphdr) + 18;
+			data_offset = (u8 *)udp + sizeof(struct udphdr) - skb->data + 18;
+		} else {
+			data_len -= sizeof(struct udphdr);
+			data_offset = (u8 *)udp + sizeof(struct udphdr) - skb->data;
+		}
+	} else {
+		data_len -= sizeof(struct udphdr);
+		data_offset = (u8 *)udp + sizeof(struct udphdr) - skb->data;
+	}
 	if (unlikely(!pskb_may_pull(skb,
 				data_offset + sizeof(struct message_header)) ||
 		     pskb_trim(skb, data_len + data_offset) < 0))
@@ -151,7 +161,7 @@
 		net_dbg_ratelimited("%s: Receiving handshake initiation from peer %llu (%pISpfsc)\n",
