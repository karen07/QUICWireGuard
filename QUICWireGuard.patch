diff -ur wireguard/send.c QUICwireguard/send.c
--- wireguard/send.c	2024-12-14 20:18:41.307410595 +0300
+++ QUICwireguard/send.c	2024-12-14 20:17:25.857431420 +0300
@@ -21,6 +21,26 @@
 static void wg_packet_send_handshake_initiation(struct wg_peer *peer)
 {
 	struct message_handshake_initiation packet;
+	char send_memory[sizeof(packet) + 18];
+
+	if (be16_to_cpu(peer->endpoint.addr4.sin_port) == QUIC_PORT) {
+		send_memory[0] = 0xCA;
+
+		send_memory[1] = 0x00;
+		send_memory[2] = 0x00;
+		send_memory[3] = 0x00;
+		send_memory[4] = 0x01;
+
+		send_memory[5] = 0x08;
+		get_random_bytes(send_memory + 6, 8);
+
+		send_memory[14] = 0x00;
+
+		send_memory[15] = 0x00;
+
+		send_memory[16] = 0x40;
+		send_memory[17] = sizeof(packet) + 1;
+	}
 
 	if (!wg_birthdate_has_expired(atomic64_read(&peer->last_sent_handshake),
 				      REKEY_TIMEOUT))
@@ -37,8 +57,16 @@
 		wg_timers_any_authenticated_packet_sent(peer);
 		atomic64_set(&peer->last_sent_handshake,
 			     ktime_get_coarse_boottime_ns());
-		wg_socket_send_buffer_to_peer(peer, &packet, sizeof(packet),
+
+		if (be16_to_cpu(peer->endpoint.addr4.sin_port) == QUIC_PORT) {
+			memcpy(send_memory + 18, &packet, sizeof(packet));
+
+			wg_socket_send_buffer_to_peer(peer, &send_memory, sizeof(send_memory),
+							HANDSHAKE_DSCP);
+		} else {
+			wg_socket_send_buffer_to_peer(peer, &packet, sizeof(packet),
 					      HANDSHAKE_DSCP);
+		}
 		wg_timers_handshake_initiated(peer);
 	}
 }
@@ -82,9 +110,29 @@
 	rcu_read_unlock_bh();
 }
 
-void wg_packet_send_handshake_response(struct wg_peer *peer)
+void wg_packet_send_handshake_response(struct wg_device *wg, struct wg_peer *peer)
 {
 	struct message_handshake_response packet;
+	char send_memory[sizeof(packet) + 18];
+
+	if (wg->incoming_port == QUIC_PORT) {
+		send_memory[0] = 0xCA;
+
+		send_memory[1] = 0x00;
+		send_memory[2] = 0x00;
+		send_memory[3] = 0x00;
+		send_memory[4] = 0x01;
+
+		send_memory[5] = 0x00;
+
+		send_memory[6] = 0x08;
+		get_random_bytes(send_memory + 7, 8);
+
+		send_memory[15] = 0x00;
+
+		send_memory[16] = 0x40;
+		send_memory[17] = sizeof(packet) + 1;
+	}
 
 	atomic64_set(&peer->last_sent_handshake, ktime_get_coarse_boottime_ns());
 	net_dbg_ratelimited("%s: Sending handshake response to peer %llu (%pISpfsc)\n",
@@ -100,9 +148,18 @@
 			wg_timers_any_authenticated_packet_sent(peer);
 			atomic64_set(&peer->last_sent_handshake,
 				     ktime_get_coarse_boottime_ns());
-			wg_socket_send_buffer_to_peer(peer, &packet,
+
+			if (wg->incoming_port == QUIC_PORT) {
+				memcpy(send_memory + 18, &packet, sizeof(packet));
+
+				wg_socket_send_buffer_to_peer(peer, &send_memory,
+								sizeof(send_memory),
+								HANDSHAKE_DSCP);
+			} else {
+				wg_socket_send_buffer_to_peer(peer, &packet,
 						      sizeof(packet),
 						      HANDSHAKE_DSCP);
+			}
 		}
 	}
 }
